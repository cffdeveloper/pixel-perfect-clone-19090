# Supabase (required for app + server)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Vite client (same project as above)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# Public site URL (OAuth redirects in SSR/build; optional locally — defaults to window.origin)
VITE_SITE_URL=http://localhost:8080
# Production (Render): https://offshoreproperties.onrender.com

# Render: set all vars above in Dashboard → Environment; start command is npm run start

# Admin portal (/adminlogin) — server-only, never expose as VITE_*
ADMIN_PASSWORD=change-me-to-a-strong-password

# Google Maps (Maps JavaScript API + Geocoding API + Maps Embed API)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_GOOGLE_MAP_ID=DEMO_MAP_ID

# AI property concierge (optional)
LOVABLE_API_KEY=your_lovable_api_key

# --- Supabase Auth (Dashboard → Authentication) ---
# 1. Enable Email provider (confirm email on or off per your preference)
# 2. Enable Google provider → add Client ID + Secret from Google Cloud Console
# 3. URL Configuration (add EVERY domain users visit — missing URL = "redirect not allowed"):
#    Site URL: https://offshoreproperties.onrender.com  (or your custom domain)
#    Redirect URLs (one per line):
#      http://localhost:8080/auth/callback
#      http://localhost:8080/auth/reset-password
#      https://offshoreproperties.onrender.com/auth/callback
#      https://offshoreproperties.onrender.com/auth/reset-password
#      https://www.offshoreproperties.co/auth/callback
#      https://www.offshoreproperties.co/auth/reset-password
#      (same for apex domain if you use offshoreproperties.co without www)
# 4. Google Cloud → OAuth client → Authorized redirect URI:
#      https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback

# CLI: npm run db:push (Dashboard → Connect → Session pooler URI)
# SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres
